RewriteEngine On

# Redirect /index.php → / (canonical root)
RewriteCond %{THE_REQUEST} ^[A-Z]+\s/index\.php[\s?] [NC]
RewriteRule ^index\.php$ / [R=301,L]

# Hide .php extension — /impressum → /impressum.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([^\.]+)$ $1.php [NC,L]
